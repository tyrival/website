---
import BaseLayout from '../layouts/BaseLayout.astro';
import SiteHeader from '../components/SiteHeader.astro';
import Hero from '../components/Hero.astro';
import ProductShowcase from '../components/ProductShowcase.astro';
import Footer from '../components/Footer.astro';
import ViabarPreview from '../components/previews/ViabarPreview.astro';
import CommuKitPreview from '../components/previews/CommuKitPreview.astro';
import VisionPreview from '../components/previews/VisionPreview.astro';
import { products } from '../content/portfolio';

const [viabar, commukit, vision] = products;
---

<BaseLayout>
  <SiteHeader />
  <div class="page-shell">
    <Hero />
    <div id="products" class="products" aria-label="Selected products">
      <ProductShowcase product={viabar}><ViabarPreview /></ProductShowcase>
      <ProductShowcase product={commukit}><CommuKitPreview /></ProductShowcase>
      <ProductShowcase product={vision}><VisionPreview /></ProductShowcase>
    </div>
    <Footer />
  </div>
</BaseLayout>
