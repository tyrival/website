      <div class="pipeline-line"></div>
      <div class="pipeline-step"><i>2</i><div><b>COMPUTE</b><span>Scale raw values</span></div></div>
      <div class="pipeline-line"></div>
      <div class="pipeline-step"><i>3</i><div><b>VALIDATE</b><span>CRC-16 check</span></div></div>
    </aside>
  </div>
</div>

