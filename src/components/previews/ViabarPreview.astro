---
const projects = [
  { name: 'Viabar 2.0', task: 'Desktop workspace polish', note: 'Refine overview report', progress: 82, color: '#1687ff', reminder: 'Today' },
  { name: 'CommuKit', task: 'Protocol pipeline', note: 'Modbus analyzer', progress: 64, color: '#ff8a34', reminder: 'Fri' },
  { name: 'Vision', task: 'Dashboard templates', note: 'Interaction states', progress: 100, color: '#36c79a', reminder: '' },
];
---

<div class="viabar-app" aria-label="Viabar application interface preview">
  <div class="app-titlebar">
    <div class="traffic-lights" aria-hidden="true"><i></i><i></i><i></i></div>
    <span>Viabar — Project Overview</span>
    <span class="titlebar-action">＋</span>
  </div>

  <div class="viabar-workspace">
    <aside class="viabar-sidebar">
      <p class="section-label">Overview</p>
      <div class="side-row active"><i></i><span>All Projects</span><b>3</b></div>
      <div class="side-row"><i></i><span>Starred</span><b>1</b></div>
      <p class="section-label archive-label">Archive</p>
      <div class="side-row"><i></i><span>Default Archive</span></div>
      <div class="sidebar-spacer"></div>
      <div class="sidebar-footer"><span>⌕</span><span>Settings</span></div>
    </aside>

    <section class="project-list" aria-label="Project cards">
      <div class="list-heading">
        <div><span class="section-label">Projects</span><strong>All Projects</strong></div>
        <span class="filter-pill">Updated</span>
      </div>
      {projects.map((project, index) => (
        <article class:list={["project-card", { selected: index === 0 }]}>
          <span class="project-accent" style={`--project-color:${project.color}`}></span>
          <div class="project-body">
            <div class="project-title"><strong>{project.name}</strong>{index === 0 && <span class="star">★</span>}</div>
            <p>{project.task}</p>
            <span class="project-note">└ {project.note}</span>
          </div>
          <div class="project-meta">
            {project.reminder && <span class="reminder">◷ {project.reminder}</span>}
            <div class="progress-ring" style={`--progress:${project.progress};--project-color:${project.color}`}><span>{project.progress}</span></div>
          </div>
        </article>
      ))}
    </section>

    <aside class="viabar-report">
      <div class="report-heading"><span class="section-label">Report</span><span>•••</span></div>
      <div class="report-period"><button class="active">Week</button><button>Month</button></div>
      <div class="report-summary"><strong>12</strong><span>items tracked</span></div>
      <div class="report-block">
        <h4>Week todo <span>4</span></h4>
        <p><i class="blue"></i><b>Viabar 2.0</b><span>Workspace polish</span></p>
        <p><i class="orange"></i><b>CommuKit</b><span>Pipeline editor</span></p>
      </div>
      <div class="report-block">
        <h4>Week done <span>8</span></h4>
        <p><i class="green"></i><b>Vision</b><span>Template system</span></p>
        <p><i class="blue"></i><b>Viabar 2.0</b><span>Search states</span></p>
      </div>
      <div class="activity-bars" aria-hidden="true">
        <i style="--h:42%"></i><i style="--h:70%"></i><i style="--h:54%"></i><i style="--h:86%"></i><i style="--h:64%"></i><i style="--h:92%"></i><i style="--h:76%"></i>
      </div>
    </aside>
  </div>
</div>

<style>
  .viabar-app { min-width: 760px; overflow: hidden; border: 1px solid var(--preview-border); border-radius: 18px; background: var(--preview-bg); color: var(--preview-text); box-shadow: var(--preview-shadow); font-family: Inter, -apple-system, BlinkMacSystemFont, "Segoe UI", sans-serif; }
  .app-titlebar { height: 44px; display: grid; grid-template-columns: 1fr auto 1fr; align-items: center; padding: 0 16px; border-bottom: 1px solid var(--preview-border); color: var(--preview-muted); font-size: 11px; font-weight: 600; }
  .traffic-lights { display: flex; gap: 7px; }
  .traffic-lights i { width: 11px; height: 11px; border-radius: 50%; background: #ff5f57; }
  .traffic-lights i:nth-child(2) { background: #febc2e; }
  .traffic-lights i:nth-child(3) { background: #28c840; }
  .titlebar-action { justify-self: end; width: 24px; height: 24px; display: grid; place-items: center; border-radius: 7px; background: color-mix(in srgb, var(--accent) 12%, transparent); color: var(--accent); font-size: 16px; }
  .viabar-workspace { height: 390px; display: grid; grid-template-columns: 170px minmax(320px, 1fr) 220px; gap: 10px; padding: 10px; background: var(--preview-canvas); }
  .viabar-sidebar, .project-list, .viabar-report { min-width: 0; border: 1px solid var(--preview-border); border-radius: 13px; background: var(--preview-panel); }
  .viabar-sidebar { display: flex; flex-direction: column; padding: 14px 11px 10px; }
  .section-label { display: block; margin: 0 7px 9px; color: var(--preview-faint); font-size: 9px; font-weight: 750; letter-spacing: .14em; text-transform: uppercase; }
  .side-row { height: 31px; display: flex; align-items: center; gap: 8px; padding: 0 8px; border-radius: 8px; color: var(--preview-muted); font-size: 11px; }
  .side-row i { width: 6px; height: 6px; border: 1px solid currentColor; border-radius: 50%; }
  .side-row b { margin-left: auto; font-size: 9px; }
  .side-row.active { background: color-mix(in srgb, var(--accent) 11%, transparent); color: var(--accent); font-weight: 650; }
  .side-row.active i { border-color: var(--accent); background: var(--accent); box-shadow: 0 0 8px color-mix(in srgb, var(--accent) 55%, transparent); }
  .archive-label { margin-top: 17px; }
  .sidebar-spacer { flex: 1; }
  .sidebar-footer { display: flex; align-items: center; gap: 8px; padding: 8px; border-top: 1px solid var(--preview-border); color: var(--preview-faint); font-size: 10px; }
  .project-list { padding: 14px; overflow: hidden; }
  .list-heading { display: flex; align-items: end; justify-content: space-between; margin-bottom: 12px; }
  .list-heading .section-label { margin: 0 0 4px; }
  .list-heading strong { font-size: 15px; }
  .filter-pill { padding: 5px 8px; border: 1px solid var(--preview-border); border-radius: 7px; color: var(--preview-muted); font-size: 9px; }
  .project-card { position: relative; min-height: 91px; display: grid; grid-template-columns: 1fr auto; gap: 12px; margin-top: 8px; padding: 13px 13px 12px 17px; overflow: hidden; border: 1px solid var(--preview-border); border-radius: 11px; background: var(--preview-panel-strong); }
  .project-card.selected { border-color: color-mix(in srgb, var(--accent) 27%, var(--preview-border)); box-shadow: 0 8px 24px color-mix(in srgb, var(--accent) 7%, transparent); }
  .project-accent { position: absolute; inset: 0 auto 0 0; width: 4px; background: var(--project-color); }
  .project-title { display: flex; align-items: center; gap: 6px; font-size: 12px; }
  .star { color: #ffb10a; font-size: 9px; }
  .project-body p { margin: 7px 0 2px; color: var(--preview-muted); font-size: 10px; }
  .project-note { color: var(--preview-faint); font-size: 9px; }
  .project-meta { display: flex; flex-direction: column; align-items: end; justify-content: space-between; }
  .reminder { color: #ff9f0a; font-size: 8px; }
  .progress-ring { --angle: calc(var(--progress) * 3.6deg); width: 34px; height: 34px; display: grid; place-items: center; border-radius: 50%; background: conic-gradient(var(--project-color) var(--angle), color-mix(in srgb, var(--project-color) 11%, transparent) 0); }
  .progress-ring::before { content: ""; grid-area: 1/1; width: 27px; height: 27px; border-radius: 50%; background: var(--preview-panel-strong); }
  .progress-ring span { position: relative; grid-area: 1/1; color: var(--project-color); font-size: 8px; font-weight: 750; }
  .viabar-report { padding: 14px; overflow: hidden; }
  .report-heading { display: flex; justify-content: space-between; color: var(--preview-faint); }
  .report-heading .section-label { margin-left: 0; }
  .report-period { display: flex; gap: 2px; padding: 3px; border-radius: 7px; background: var(--preview-canvas); }
  .report-period button { flex: 1; padding: 5px; border: 0; border-radius: 5px; background: transparent; color: var(--preview-faint); font-size: 9px; }
  .report-period button.active { background: var(--preview-panel-strong); color: var(--preview-text); box-shadow: 0 1px 4px rgb(0 0 0 / .08); }
  .report-summary { display: flex; align-items: baseline; gap: 6px; padding: 15px 0 11px; }
  .report-summary strong { font-size: 24px; }
  .report-summary span { color: var(--preview-muted); font-size: 9px; }
  .report-block { padding: 10px 0; border-top: 1px solid var(--preview-border); }
  .report-block h4 { display: flex; justify-content: space-between; margin: 0 0 7px; font-size: 10px; }
  .report-block h4 span { color: var(--preview-faint); }
  .report-block p { display: grid; grid-template-columns: 5px auto 1fr; align-items: center; gap: 5px; margin: 5px 0; font-size: 8px; }
  .report-block p i { width: 4px; height: 4px; border-radius: 50%; }
  .report-block p b { font-weight: 650; }
  .report-block p span { overflow: hidden; color: var(--preview-faint); text-overflow: ellipsis; white-space: nowrap; }
  .blue { background: #1687ff; }.orange { background: #ff8a34; }.green { background: #36c79a; }
  .activity-bars { height: 42px; display: flex; align-items: end; gap: 5px; margin-top: 7px; }
  .activity-bars i { flex: 1; height: var(--h); border-radius: 2px 2px 0 0; background: linear-gradient(#1aa0ff, #1687ff); opacity: .75; }
  @media (max-width: 900px) { .viabar-workspace { grid-template-columns: 150px 1fr; } .viabar-report { display: none; } }
</style>
